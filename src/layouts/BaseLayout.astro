---
import '../styles/global.css';

const {
  title = 'Vaporsoft',
  description = 'Vaporsoft builds clean digital systems with precision, atmosphere, and technical clarity.',
  themeColor = '#07080b',
  bodyClass = ''
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://vaporsoft.dev" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;700&family=Syncopate:wght@400;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet" />
    <slot name="head" />
    <title>{title}</title>
    <script is:inline>
      (function(){var t=localStorage.getItem('akira-theme');if(t==='light')document.documentElement.className='akira-light';})();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />
    <script is:inline>
      (function(){
        var toggle=document.querySelector('[data-theme-toggle]');
        if(!toggle)return;
        var label=toggle.querySelector('[data-theme-label]');
        function sync(){
          var light=document.documentElement.classList.contains('akira-light');
          if(label)label.textContent=light?'LIGHT':'DARK';
          document.body.classList.toggle('akira-light',light);
        }
        sync();
        toggle.addEventListener('click',function(){
          document.documentElement.classList.toggle('akira-light');
          localStorage.setItem('akira-theme',document.documentElement.classList.contains('akira-light')?'light':'dark');
          sync();
        });
      })();
    </script>
  </body>
</html>