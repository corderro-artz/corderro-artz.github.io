---
import '../styles/global.css';

const {
  title = 'Vaporsoft',
  description = 'Vaporsoft builds clean digital systems with precision, atmosphere, and technical clarity.',
  themeColor = '#07080b',
  bodyClass = ''
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL('/vaporsoft-logo.svg', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Vaporsoft',
  url: Astro.site,
  logo: ogImageUrl.href,
  description
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#07080b" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f2ede6" />
    <meta name="color-scheme" content="dark light" />
    <meta name="author" content="Vaporsoft" />
    <meta name="application-name" content="Vaporsoft" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Vaporsoft" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="256" />
    <meta property="og:image:height" content="256" />
    <meta property="og:image:alt" content="Vaporsoft brand mark" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <link rel="icon" type="image/svg+xml" href="/vaporsoft-favicon.svg" data-favicon data-dark-href="/vaporsoft-favicon.svg" data-light-href="/vaporsoft-favicon-light.svg" />
    <link rel="apple-touch-icon" type="image/svg+xml" href="/vaporsoft-logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;700&family=Syncopate:wght@400;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json">{JSON.stringify(jsonLd)}</script>
    <slot name="head" />
    <title>{title}</title>
    <script is:inline>
      (function(){
        function setFavicon(isLight){
          var icons=document.querySelectorAll('link[data-favicon]');
          icons.forEach(function(link){
            var href=isLight?link.getAttribute('data-light-href'):link.getAttribute('data-dark-href');
            if(href)link.setAttribute('href',href);
          });
        }
        var t=localStorage.getItem('vapor-theme');
        document.documentElement.classList.toggle('vapor-light',t!=='dark');
        setFavicon(document.documentElement.classList.contains('vapor-light'));
        window.__vaporSetFavicon=setFavicon;
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <slot />
    <script is:inline>
      (function(){
        // Theme toggle
        var toggle=document.querySelector('[data-theme-toggle]');
        if(toggle){
          var label=toggle.querySelector('[data-theme-label]');
          function sync(){
            var light=document.documentElement.classList.contains('vapor-light');
            if(label)label.textContent=light?'LIGHT':'DARK';
            document.body.classList.toggle('vapor-light',light);
            if(window.__vaporSetFavicon)window.__vaporSetFavicon(light);
          }
          sync();
          toggle.addEventListener('click',function(){
            document.documentElement.classList.toggle('vapor-light');
            localStorage.setItem('vapor-theme',document.documentElement.classList.contains('vapor-light')?'light':'dark');
            sync();
          });
        }

        // Landing / arch glow animation (GPU-composited: opacity + transform only)
        var snap=document.querySelector('.vapor-snap-container');
        var noiseLand=document.querySelector('.vapor-noise--landing');
        var noiseArch=document.querySelector('.vapor-noise--arch');
        var scrollCue=document.querySelector('.vapor-scroll-cue');
        if(scrollCue){
          scrollCue.addEventListener('animationend',function(){
            scrollCue.style.animation='none';
            scrollCue.style.opacity='1';
          },{once:true});
        }
        if(snap&&noiseLand){
          var ticking=false;
          function onScroll(){
            if(!ticking){ticking=true;requestAnimationFrame(updateGlow);}
          }
          function updateGlow(){
            ticking=false;
            var y=snap.scrollTop;
            var h=snap.offsetHeight;
            var t=Math.min(1,Math.max(0,y/h));
            // Page 1: fade + shrink to nothing
            noiseLand.style.opacity=(1-t)*0.32;
            noiseLand.style.transform='scale('+(1-t)+')';
            // Page 2: fade + grow from nothing
            if(noiseArch){
              noiseArch.style.opacity=t*0.32;
              noiseArch.style.transform='scale('+t+')';
            }
            if(scrollCue){
              scrollCue.style.opacity=t<0.1?(1-t/0.1):0;
            }
          }
          snap.addEventListener('scroll',onScroll,{passive:true});
          updateGlow();

          // Snap enforcement — debounced scroll-end detection
          var snapPages=snap.querySelectorAll('.vapor-snap-page');
          var snapTimer=null;
          function enforceSnap(){
            clearTimeout(snapTimer);
            snapTimer=setTimeout(function(){
              var scrollTop=snap.scrollTop;
              var closest=null;
              var minDist=Infinity;
              snapPages.forEach(function(page){
                var dist=Math.abs(page.offsetTop-scrollTop);
                if(dist<minDist){minDist=dist;closest=page;}
              });
              if(closest&&minDist>2){
                closest.scrollIntoView({behavior:'smooth'});
              }
            },120);
          }
          snap.addEventListener('scroll',enforceSnap,{passive:true});
        }
      })();
    </script>
  </body>
</html>