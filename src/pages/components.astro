---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = Astro.site ?? new URL('https://www.vaporsoft.dev');
const componentsStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Vaporsoft Components',
    url: new URL('/components/', siteUrl).href,
    description: 'Vaporsoft theme component reference for surfaces, containers, and layout patterns.',
    isPartOf: {
      '@type': 'WebSite',
      name: 'Vaporsoft',
      url: siteUrl.href
    }
  }
];
---

<BaseLayout
  title="Vaporsoft Components | Design System Reference"
  description="Vaporsoft theme component reference for surfaces, containers, layout patterns, and reusable UI structure."
  themeColor="#f2ede6"
  bodyClass="vapor-body"
  keywords={['Vaporsoft components', 'design system', 'UI patterns', 'Astro component reference']}
  structuredData={componentsStructuredData}
>
  <main class="vapor-site">
    <div class="vapor-noise"></div>

    <header class="vapor-topbar">
      <a class="vapor-brand" href="/">
        <span class="vapor-brand-mark"></span>
        <span class="vapor-brand-lockup">
          <span class="vapor-brand-name">Vaporsoft</span>
          <span class="vapor-brand-subtitle">Components</span>
        </span>
      </a>

      <nav class="vapor-nav">
        <a href="/">Home</a>
        <a href="#tokens">Tokens</a>
        <a href="#catalogue">Catalogue</a>
        <a href="#preview">Preview</a>
        <a href="/contact/">Contact</a>
        <button class="vapor-theme-toggle" data-theme-toggle aria-label="Toggle theme">
          <span class="vapor-theme-toggle-dot"></span>
          <span data-theme-label>Dark</span>
        </button>
      </nav>
    </header>

    <section class="vapor-section" id="tokens">
      <div class="vapor-section-head">
        <p class="vapor-kicker">Vaporsoft Theme</p>
        <h1 class="vapor-title">Component Reference</h1>
        <p class="vapor-intro">
          Reusable surfaces, containers, and layout patterns from the Vaporsoft design system.
        </p>
      </div>

      <div class="vapor-card-grid">
        <div class="vapor-panel vapor-card">
          <p class="vapor-label">Accent</p>
          <div class="vapor-token-chip">
            <span class="vapor-token-swatch"></span>
            <span class="vapor-meta">Carmine / #A11F31</span>
          </div>
        </div>
        <div class="vapor-panel vapor-card">
          <p class="vapor-label">Typography</p>
          <div class="vapor-ledger">
            <div class="vapor-ledger-row">
              <span>Display</span>
              <strong>Syncopate</strong>
            </div>
            <div class="vapor-ledger-row">
              <span>Headings</span>
              <strong>Space Grotesk</strong>
            </div>
            <div class="vapor-ledger-row">
              <span>Body</span>
              <strong>Manrope</strong>
            </div>
            <div class="vapor-ledger-row">
              <span>Accent</span>
              <strong>Zen Kaku Gothic New</strong>
            </div>
          </div>
        </div>
        <div class="vapor-panel vapor-card">
          <p class="vapor-label">Surfaces</p>
          <div class="vapor-ledger">
            <div class="vapor-ledger-row">
              <span>Dark</span>
              <strong>#07080b</strong>
            </div>
            <div class="vapor-ledger-row">
              <span>Light</span>
              <strong>#f2ede6</strong>
            </div>
            <div class="vapor-ledger-row">
              <span>Corners</span>
              <strong>Rotated by depth</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="vapor-section" id="catalogue">
      <div class="vapor-section-head">
        <p class="vapor-kicker">Catalogue</p>
        <h2 class="vapor-title">Classes and containers.</h2>
      </div>

      <div class="vapor-class-grid">
        <article class="vapor-class-card">
          <p class="vapor-class-type">Container</p>
          <h3>.vapor-site</h3>
          <p>Top-level page shell. Max-width constraint and vertical padding.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Surface</p>
          <h3>.vapor-frame</h3>
          <p>Primary bordered surface with corner brackets. Used for hero and ledger blocks.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Surface</p>
          <h3>.vapor-panel</h3>
          <p>General-purpose card or module container with corner brackets.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Layout</p>
          <h3>.vapor-hero</h3>
          <p>Two-column hero layout. Pairs .vapor-copy with .vapor-aside.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Layout</p>
          <h3>.vapor-card-grid</h3>
          <p>Three-column content grid for compact information blocks.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Layout</p>
          <h3>.vapor-band</h3>
          <p>Two-column callout section pairing copy with a visual element.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Data</p>
          <h3>.vapor-ledger</h3>
          <p>Stacked metadata rows for tokens, specs, or project information.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Element</p>
          <h3>.vapor-button</h3>
          <p>Action element. Variants: --primary (carmine) and --secondary (neutral).</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Element</p>
          <h3>.vapor-rule</h3>
          <p>Horizontal divider with centered kanji accent text.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Variant</p>
          <h3>.vapor-light</h3>
          <p>Theme override. Converts all surfaces and text to light-mode presentation.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Utility</p>
          <h3>.vapor-noise</h3>
          <p>Radial gradient overlay for atmospheric texture on dark surfaces.</p>
        </article>
        <article class="vapor-class-card">
          <p class="vapor-class-type">Utility</p>
          <h3>.vapor-signal-map</h3>
          <p>Decorative circuit-board visual with routes, nodes, and pulse animation.</p>
        </article>
      </div>
    </section>

    <section class="vapor-showcase-block" id="preview">
      <div class="vapor-section-head">
        <p class="vapor-kicker">Live Preview</p>
        <h2 class="vapor-title">Surfaces in context.</h2>
        <div class="vapor-preview-tabs">
          <button class="vapor-preview-tab" aria-selected="true" data-preview-mode="dark">Dark</button>
          <button class="vapor-preview-tab" aria-selected="false" data-preview-mode="light">Light</button>
        </div>
      </div>

      <div class="vapor-preview" id="preview-container">
        <div class="vapor-topbar">
          <div class="vapor-brand">
            <span class="vapor-brand-mark"></span>
            <span class="vapor-brand-lockup">
              <span class="vapor-brand-name">Vaporsoft</span>
              <span class="vapor-brand-subtitle" id="preview-subtitle">Dark Preview</span>
            </span>
          </div>
          <div class="vapor-nav">
            <span>Hero</span>
            <span>Cards</span>
            <span>Band</span>
          </div>
        </div>

        <div class="vapor-showcase-stack">
          <section class="vapor-hero vapor-frame">
            <div class="vapor-copy">
              <p class="vapor-kicker">Sample Hero</p>
              <h2 class="vapor-title">Primary page composition.</h2>
              <p class="vapor-intro">Frame + copy + aside panel. Corner brackets rotate at each nesting depth.</p>
              <div class="vapor-actions">
                <span class="vapor-button vapor-button--primary">Primary action</span>
                <span class="vapor-button vapor-button--secondary">Secondary action</span>
              </div>
            </div>
            <aside class="vapor-aside vapor-panel">
              <div class="vapor-ledger">
                <div class="vapor-ledger-row"><span>.vapor-kicker</span><strong>Section notation</strong></div>
                <div class="vapor-ledger-row"><span>.vapor-title</span><strong>Uppercase heading</strong></div>
                <div class="vapor-ledger-row"><span>.vapor-intro</span><strong>Body lead copy</strong></div>
              </div>
            </aside>
          </section>

          <div class="vapor-card-grid">
            <article class="vapor-card vapor-panel">
              <p class="vapor-label">.vapor-panel</p>
              <h3>Compact module</h3>
              <p>Reusable surface for service notes, features, or process items.</p>
            </article>
            <article class="vapor-card vapor-panel">
              <p class="vapor-label">.vapor-card-grid</p>
              <h3>Grid parent</h3>
              <p>Three-column layout with consistent spacing.</p>
            </article>
            <article class="vapor-card vapor-panel">
              <p class="vapor-label">.vapor-ledger</p>
              <h3>Spec module</h3>
              <p>Technical metadata rows rather than marketing bullets.</p>
            </article>
          </div>

          <section class="vapor-band">
            <div class="vapor-band-copy">
              <p class="vapor-kicker">.vapor-band</p>
              <h2>Two-column section pattern.</h2>
              <p>Pairs editorial copy with structured visual content on the right.</p>
            </div>
            <div class="vapor-signal-map" aria-hidden="true">
              <div class="vapor-route vapor-route--a"></div>
              <div class="vapor-route vapor-route--b"></div>
              <div class="vapor-route vapor-route--c"></div>
              <div class="vapor-node vapor-node--a"></div>
              <div class="vapor-node vapor-node--b vapor-node--accent"></div>
              <div class="vapor-node vapor-node--c"></div>
              <div class="vapor-pulse"></div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <footer class="vapor-footer">
      <p>Vaporsoft</p>
      <div class="vapor-footer-meta">
        <p>&copy; 2026 Vaporsoft. All rights reserved.</p>
        <p class="vapor-footer-contact"><a href="/contact/">Contact</a></p>
      </div>
    </footer>
  </main>

  <script is:inline>
    (function(){
      var tabs = document.querySelectorAll('[data-preview-mode]');
      var container = document.getElementById('preview-container');
      var subtitle = document.getElementById('preview-subtitle');
      if (!tabs.length || !container) return;

      tabs.forEach(function(tab){
        tab.addEventListener('click', function(){
          var mode = tab.getAttribute('data-preview-mode');
          tabs.forEach(function(t){ t.setAttribute('aria-selected','false'); });
          tab.setAttribute('aria-selected','true');
          if (mode === 'light') {
            container.classList.add('vapor-light');
            if(subtitle) subtitle.textContent = 'Light Preview';
          } else {
            container.classList.remove('vapor-light');
            if(subtitle) subtitle.textContent = 'Dark Preview';
          }
        });
      });
    })();
  </script>
</BaseLayout>