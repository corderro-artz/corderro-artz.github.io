---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vaporsoft — Components"
  description="Akira theme component reference. Surfaces, containers, and layout patterns."
  themeColor="#07080b"
  bodyClass="akira-body"
>
  <main class="akira-site">
    <div class="akira-noise"></div>

    <header class="akira-topbar">
      <a class="akira-brand" href="/">
        <span class="akira-brand-mark"></span>
        <span class="akira-brand-lockup">
          <span class="akira-brand-name">Vaporsoft</span>
          <span class="akira-brand-subtitle">Components</span>
        </span>
      </a>

      <nav class="akira-nav">
        <a href="/">Home</a>
        <a href="#tokens">Tokens</a>
        <a href="#catalogue">Catalogue</a>
        <a href="#preview">Preview</a>
        <button class="akira-theme-toggle" data-theme-toggle aria-label="Toggle theme">
          <span class="akira-theme-toggle-dot"></span>
          <span data-theme-label>Dark</span>
        </button>
      </nav>
    </header>

    <section class="akira-section" id="tokens">
      <div class="akira-section-head">
        <p class="akira-kicker">Akira Theme</p>
        <h1 class="akira-title">Component Reference</h1>
        <p class="akira-intro">
          Reusable surfaces, containers, and layout patterns from the Vaporsoft design system.
        </p>
      </div>

      <div class="akira-card-grid">
        <div class="akira-panel akira-card">
          <p class="akira-label">Accent</p>
          <div class="akira-token-chip">
            <span class="akira-token-swatch"></span>
            <span class="akira-meta">Carmine / #A11F31</span>
          </div>
        </div>
        <div class="akira-panel akira-card">
          <p class="akira-label">Typography</p>
          <div class="akira-ledger">
            <div class="akira-ledger-row">
              <span>Display</span>
              <strong>Syncopate</strong>
            </div>
            <div class="akira-ledger-row">
              <span>Headings</span>
              <strong>Space Grotesk</strong>
            </div>
            <div class="akira-ledger-row">
              <span>Body</span>
              <strong>Manrope</strong>
            </div>
            <div class="akira-ledger-row">
              <span>Accent</span>
              <strong>Zen Kaku Gothic New</strong>
            </div>
          </div>
        </div>
        <div class="akira-panel akira-card">
          <p class="akira-label">Surfaces</p>
          <div class="akira-ledger">
            <div class="akira-ledger-row">
              <span>Dark</span>
              <strong>#07080b</strong>
            </div>
            <div class="akira-ledger-row">
              <span>Light</span>
              <strong>#f2ede6</strong>
            </div>
            <div class="akira-ledger-row">
              <span>Corners</span>
              <strong>Rotated by depth</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="akira-section" id="catalogue">
      <div class="akira-section-head">
        <p class="akira-kicker">Catalogue</p>
        <h2 class="akira-title">Classes and containers.</h2>
      </div>

      <div class="akira-class-grid">
        <article class="akira-class-card">
          <p class="akira-class-type">Container</p>
          <h3>.akira-site</h3>
          <p>Top-level page shell. Max-width constraint and vertical padding.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Surface</p>
          <h3>.akira-frame</h3>
          <p>Primary bordered surface with corner brackets. Used for hero and ledger blocks.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Surface</p>
          <h3>.akira-panel</h3>
          <p>General-purpose card or module container with corner brackets.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Layout</p>
          <h3>.akira-hero</h3>
          <p>Two-column hero layout. Pairs .akira-copy with .akira-aside.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Layout</p>
          <h3>.akira-card-grid</h3>
          <p>Three-column content grid for compact information blocks.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Layout</p>
          <h3>.akira-band</h3>
          <p>Two-column callout section pairing copy with a visual element.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Data</p>
          <h3>.akira-ledger</h3>
          <p>Stacked metadata rows for tokens, specs, or project information.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Element</p>
          <h3>.akira-button</h3>
          <p>Action element. Variants: --primary (carmine) and --secondary (neutral).</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Element</p>
          <h3>.akira-rule</h3>
          <p>Horizontal divider with centered kanji accent text.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Variant</p>
          <h3>.akira-light</h3>
          <p>Theme override. Converts all surfaces and text to light-mode presentation.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Utility</p>
          <h3>.akira-noise</h3>
          <p>Radial gradient overlay for atmospheric texture on dark surfaces.</p>
        </article>
        <article class="akira-class-card">
          <p class="akira-class-type">Utility</p>
          <h3>.akira-signal-map</h3>
          <p>Decorative circuit-board visual with routes, nodes, and pulse animation.</p>
        </article>
      </div>
    </section>

    <section class="akira-showcase-block" id="preview">
      <div class="akira-section-head">
        <p class="akira-kicker">Live Preview</p>
        <h2 class="akira-title">Surfaces in context.</h2>
        <div class="akira-preview-tabs">
          <button class="akira-preview-tab" aria-selected="true" data-preview-mode="dark">Dark</button>
          <button class="akira-preview-tab" aria-selected="false" data-preview-mode="light">Light</button>
        </div>
      </div>

      <div class="akira-preview" id="preview-container">
        <div class="akira-topbar">
          <div class="akira-brand">
            <span class="akira-brand-mark"></span>
            <span class="akira-brand-lockup">
              <span class="akira-brand-name">Vaporsoft</span>
              <span class="akira-brand-subtitle" id="preview-subtitle">Dark Preview</span>
            </span>
          </div>
          <div class="akira-nav">
            <span>Hero</span>
            <span>Cards</span>
            <span>Band</span>
          </div>
        </div>

        <div class="akira-showcase-stack">
          <section class="akira-hero akira-frame">
            <div class="akira-copy">
              <p class="akira-kicker">Sample Hero</p>
              <h2 class="akira-title">Primary page composition.</h2>
              <p class="akira-intro">Frame + copy + aside panel. Corner brackets rotate at each nesting depth.</p>
              <div class="akira-actions">
                <span class="akira-button akira-button--primary">Primary action</span>
                <span class="akira-button akira-button--secondary">Secondary action</span>
              </div>
            </div>
            <aside class="akira-aside akira-panel">
              <div class="akira-ledger">
                <div class="akira-ledger-row"><span>.akira-kicker</span><strong>Section notation</strong></div>
                <div class="akira-ledger-row"><span>.akira-title</span><strong>Uppercase heading</strong></div>
                <div class="akira-ledger-row"><span>.akira-intro</span><strong>Body lead copy</strong></div>
              </div>
            </aside>
          </section>

          <div class="akira-card-grid">
            <article class="akira-card akira-panel">
              <p class="akira-label">.akira-panel</p>
              <h3>Compact module</h3>
              <p>Reusable surface for service notes, features, or process items.</p>
            </article>
            <article class="akira-card akira-panel">
              <p class="akira-label">.akira-card-grid</p>
              <h3>Grid parent</h3>
              <p>Three-column layout with consistent spacing.</p>
            </article>
            <article class="akira-card akira-panel">
              <p class="akira-label">.akira-ledger</p>
              <h3>Spec module</h3>
              <p>Technical metadata rows rather than marketing bullets.</p>
            </article>
          </div>

          <section class="akira-band">
            <div class="akira-band-copy">
              <p class="akira-kicker">.akira-band</p>
              <h2>Two-column section pattern.</h2>
              <p>Pairs editorial copy with structured visual content on the right.</p>
            </div>
            <div class="akira-signal-map" aria-hidden="true">
              <div class="akira-route akira-route--a"></div>
              <div class="akira-route akira-route--b"></div>
              <div class="akira-route akira-route--c"></div>
              <div class="akira-node akira-node--a"></div>
              <div class="akira-node akira-node--b akira-node--accent"></div>
              <div class="akira-node akira-node--c"></div>
              <div class="akira-pulse"></div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <footer class="akira-footer">
      <p>Vaporsoft</p>
      <p>&copy; 2026 Vaporsoft. All rights reserved.</p>
    </footer>
  </main>

  <script is:inline>
    (function(){
      var tabs = document.querySelectorAll('[data-preview-mode]');
      var container = document.getElementById('preview-container');
      var subtitle = document.getElementById('preview-subtitle');
      if (!tabs.length || !container) return;

      tabs.forEach(function(tab){
        tab.addEventListener('click', function(){
          var mode = tab.getAttribute('data-preview-mode');
          tabs.forEach(function(t){ t.setAttribute('aria-selected','false'); });
          tab.setAttribute('aria-selected','true');
          if (mode === 'light') {
            container.classList.add('akira-light');
            if(subtitle) subtitle.textContent = 'Light Preview';
          } else {
            container.classList.remove('akira-light');
            if(subtitle) subtitle.textContent = 'Dark Preview';
          }
        });
      });
    })();
  </script>
</BaseLayout>