---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';

const siteUrl = Astro.site ?? new URL('https://www.vaporsoft.dev');
const homePageStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Vaporsoft',
    url: new URL('/', siteUrl).href,
    description: 'Vaporsoft builds software contracting systems, MCP servers, and browser-first digital tools.',
    isPartOf: {
      '@type': 'WebSite',
      name: 'Vaporsoft',
      url: siteUrl.href
    },
    mainEntity: {
      '@type': 'ItemList',
      name: 'Vaporsoft products',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Akira',
          url: 'https://github.com/corderro-artz/akira'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Kata',
          url: 'https://github.com/corderro-artz/kata'
        }
      ]
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareSourceCode',
    name: 'Akira',
    url: 'https://github.com/corderro-artz/akira',
    codeRepository: 'https://github.com/corderro-artz/akira',
    author: {
      '@type': 'Organization',
      name: 'Vaporsoft'
    },
    description: 'A cross-platform system introspection library providing unified hardware and OS telemetry across Windows, Linux, and macOS.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareSourceCode',
    name: 'Kata',
    url: 'https://github.com/corderro-artz/kata',
    codeRepository: 'https://github.com/corderro-artz/kata',
    author: {
      '@type': 'Organization',
      name: 'Vaporsoft'
    },
    description: 'A local-first structured text parser and visualizer for inspecting, comparing, and exporting structured text entirely in-browser.'
  }
];
---

<BaseLayout
  title="Vaporsoft | Native, Web, AI, and Digital Assets"
  description="Vaporsoft builds native applications, web platforms, AI tooling, and digital assets — including Akira and Kata."
  themeColor="#f2ede6"
  bodyClass="vapor-body"
  keywords={[
    'software contracting',
    'MCP server',
    'digital tools',
    'Akira',
    'Kata',
    'cross-platform telemetry',
    'local-first tools'
  ]}
  structuredData={homePageStructuredData}
>
  <div class="vapor-snap-container">

    <!-- ── Page 1 · Landing ── -->
    <section class="vapor-snap-page">
      <main class="vapor-site vapor-landing">
        <div class="vapor-noise vapor-noise--landing"></div>

        <div class="vapor-landing-center">
          <span class="vapor-brand-mark vapor-landing-mark"></span>

          <h1 class="vapor-heading">VAPORSOFT</h1>

          <div class="vapor-rule">
            <span></span>
            <strong>仮想</strong>
            <span></span>
          </div>

          <p class="vapor-landing-tagline">
            <span class="vapor-tagline-segment vapor-tagline-segment--muted">Native</span>
            <span class="vapor-tagline-sep" aria-hidden="true"></span>
            <span class="vapor-tagline-segment vapor-tagline-segment--muted">Web</span>
            <span class="vapor-tagline-sep" aria-hidden="true"></span>
            <span class="vapor-tagline-segment vapor-tagline-segment--accent">AI</span>
            <span class="vapor-tagline-sep" aria-hidden="true"></span>
            <span class="vapor-tagline-segment vapor-tagline-segment--accent">Assets</span>
          </p>

          <nav class="vapor-landing-nav" aria-label="Primary">
            <button type="button" class="vapor-inline-link" data-scroll-target="products" aria-controls="products">Products</button>
            <a class="vapor-inline-link" href="/components/">Components</a>
            <a class="vapor-inline-link" href="/contact/">Contact</a>
            <button type="button" class="vapor-theme-toggle" data-theme-toggle aria-label="Toggle theme">
              <span class="vapor-theme-toggle-dot"></span>
              <span data-theme-label>LIGHT</span>
            </button>
          </nav>
        </div>

        <div class="vapor-scroll-cue" aria-hidden="true">
          <span class="vapor-scroll-cue-label">Scroll</span>
          <span class="vapor-scroll-cue-line"></span>
        </div>
      </main>
    </section>

    <!-- ── Page 2 · Products ── -->
    <section class="vapor-snap-page" id="products">
      <div class="vapor-site vapor-arch">
        <div class="vapor-noise vapor-noise--arch"></div>

        <header class="vapor-arch-header">
          <p class="vapor-kicker">Fabric & Surface</p>
          <h2 class="vapor-title">A single loom</h2>
          <div class="vapor-rule vapor-rule--compact">
            <span></span>
            <strong>織</strong>
            <span></span>
          </div>
          <h2 class="vapor-title">to spin many threads</h2>
          <p class="vapor-intro vapor-arch-summary">
            Explore the Vaporsoft product catalog: Akira for cross-platform system telemetry, Kata for local-first structured text parsing, and MCP surfaces built on the same technical foundation.
          </p>
        </header>

        <nav class="vapor-product-nav" aria-label="Product navigation">
          <button type="button" class="vapor-product-tab" data-product="akira" aria-selected="true">Akira</button>
          <button type="button" class="vapor-product-tab" data-product="kata" aria-selected="false">Kata</button>
        </nav>

        <div class="vapor-product-panels">

          <!-- Akira ecosystem -->
          <div class="vapor-product-panel vapor-product-panel--active" data-product-panel="akira" aria-hidden="false">
            <div class="vapor-arch-stack">

              <!-- Upper tier: surfaces -->
              <div class="vapor-arch-tier vapor-arch-tier--upper">
                <ProductCard
                  name="Akira MCP Server"
                  description="An MCP server built on Akira, exposing Akira tooling through MCP."
                  icon="akira"
                  label="SURFACE"
                  variant="surface"
                />
                <ProductCard
                  name="[Future]"
                  description="Another system in the pipeline — same foundation, new surface."
                  label="SURFACE"
                  variant="future"
                />
              </div>

              <!-- Connector lines -->
              <div class="vapor-arch-connectors" aria-hidden="true">
                <div class="vapor-arch-connector vapor-arch-connector--left"></div>
                <div class="vapor-arch-connector vapor-arch-connector--right"></div>
                <div class="vapor-arch-connector-trunk"></div>
              </div>

              <!-- Base tier: fabric -->
              <div class="vapor-arch-tier vapor-arch-tier--base">
                <ProductCard
                  name="Akira"
                  description="A cross-platform system introspection library providing unified hardware and OS telemetry across Windows, Linux, and macOS."
                  icon="akira"
                  href="https://github.com/corderro-artz/akira"
                  label="FABRIC"
                  variant="foundation"
                />
              </div>

            </div>
          </div>

          <!-- Kata standalone -->
          <div class="vapor-product-panel" data-product-panel="kata" aria-hidden="true" hidden>
            <div class="vapor-arch-stack">
              <div class="vapor-arch-tier vapor-arch-tier--base">
                <ProductCard
                  name="Kata"
                  description="A local-first structured text parser and visualizer. Parse, inspect, compare, and export structured text entirely in-browser."
                  icon="kata"
                  href="https://github.com/corderro-artz/kata"
                  label="SURFACE"
                  variant="standalone"
                />
              </div>
            </div>
          </div>

        </div>

        <footer class="vapor-landing-footer">
          <p>&copy; 2026 Vaporsoft. All rights reserved.</p>
        </footer>
      </div>
    </section>

  </div>

  <script is:inline>
    (function(){
      var scrollTargets = document.querySelectorAll('[data-scroll-target]');
      scrollTargets.forEach(function(trigger) {
        trigger.addEventListener('click', function() {
          var targetId = trigger.getAttribute('data-scroll-target');
          var target = targetId ? document.getElementById(targetId) : null;
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });

      // Product navigation
      var tabs = document.querySelectorAll('[data-product]');
      var panels = document.querySelectorAll('[data-product-panel]');
      if (tabs.length && panels.length) {
        tabs.forEach(function(tab) {
          tab.addEventListener('click', function() {
            var product = tab.getAttribute('data-product');
            tabs.forEach(function(t) { t.setAttribute('aria-selected', 'false'); });
            tab.setAttribute('aria-selected', 'true');
            panels.forEach(function(p) {
              if (p.getAttribute('data-product-panel') === product) {
                p.classList.add('vapor-product-panel--active');
                p.hidden = false;
                p.setAttribute('aria-hidden', 'false');
              } else {
                p.classList.remove('vapor-product-panel--active');
                p.hidden = true;
                p.setAttribute('aria-hidden', 'true');
              }
            });
          });
        });
      }
    })();
  </script>
</BaseLayout>