---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vaporsoft"
  description="Vaporsoft — Software contracting and digital assets."
  themeColor="#f2ede6"
  bodyClass="akira-body"
>
  <main class="akira-site akira-landing">
    <div class="akira-noise"></div>

    <div class="akira-landing-center">
      <span class="akira-brand-mark akira-landing-mark"></span>

      <h1 class="akira-heading">VAPORSOFT</h1>

      <div class="akira-rule">
        <span></span>
        <strong>仮想</strong>
        <span></span>
      </div>

      <p class="akira-landing-tagline">Software Contracting & Digital Assets</p>

      <nav class="akira-landing-nav">
        <button class="akira-theme-toggle" data-theme-toggle aria-label="Toggle theme">
          <span class="akira-theme-toggle-dot"></span>
          <span data-theme-label>LIGHT</span>
        </button>
      </nav>
    </div>

    <footer class="akira-landing-footer">
      <p>&copy; 2026 Vaporsoft. All rights reserved.</p>
    </footer>
  </main>
</BaseLayout>